# Local dev environment template for stand-alone-analyzer.
# Copy to `.env` and fill in values for your machine. `.env` is gitignored.
#
# Loaded by:
# - uvicorn: pydantic-settings env_file=".env" (src/flake_analysis/db/url.py)
# - scripts/dev/start-backend.sh + start-frontend.sh: `set -a; source .env; set +a`
# - scripts/dev/w10-acceptance.sh: same source pattern
#
# Frontend reads its own VITE_* vars at build time — see web/.env if needed.

# --- Postgres (local saa_test) ---
SAA_DB_HOST=127.0.0.1
SAA_DB_PORT=5432
SAA_DB_USER=
SAA_DB_PASSWORD=
SAA_DB_NAME=saa_test

# --- Auth (dev bypass) ---
SAA_AUTH_DEV_BYPASS=1
SAA_ENV=dev

# --- S3 uploads (real AWS) ---
# AWS_PROFILE points at a profile in ~/.aws/credentials with an access key
# limited to the qpress-uploads bucket (W5-infra IAM user qpress-dev-local).
SAA_S3_BUCKET=qpress-uploads
SAA_S3_PREFIX=dev/
AWS_PROFILE=qpress-dev-local
AWS_DEFAULT_REGION=us-east-2

# --- Project root (per-scan manifest filesystem) ---
SAA_ANALYSIS_ROOT=/tmp/saa-analysis

# --- Test harness (tests/db + tests/scripts conftests) ---
SAA_TEST_DATABASE_URL=postgresql+asyncpg://USER@127.0.0.1:5432/saa_test
