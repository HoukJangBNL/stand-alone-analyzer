# Local dev environment for stand-alone-analyzer (gitignored).
# Used by uvicorn (via pydantic-settings env_file=".env" in src/flake_analysis/db/url.py).
# Frontend reads its own VITE_* vars at build time — see web/.env if needed.

# --- Postgres (local saa_test) ---
SAA_DB_HOST=127.0.0.1
SAA_DB_PORT=5432
SAA_DB_USER=houkjang
SAA_DB_PASSWORD=
SAA_DB_NAME=saa_test

# --- Auth (dev bypass) ---
SAA_AUTH_DEV_BYPASS=1
SAA_ENV=dev

# --- S3 uploads (real AWS) ---
SAA_S3_BUCKET=qpress-uploads
AWS_PROFILE=qpress-dev-local
AWS_DEFAULT_REGION=us-east-2

# --- Project root (manifest scan/run targets) ---
# Adjust if you keep analysis projects elsewhere on this host.
SAA_ANALYSIS_FOLDER=/tmp/saa-analysis

# --- Test harness (consumed by tests/db + tests/scripts conftests) ---
SAA_TEST_DATABASE_URL=postgresql+asyncpg://houkjang@127.0.0.1:5432/saa_test
SAA_S3_PREFIX=dev/
