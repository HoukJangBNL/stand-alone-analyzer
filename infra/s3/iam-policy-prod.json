{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteProdPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectTagging",
        "s3:GetObject",
        "s3:HeadObject",
        "s3:GetObjectAttributes"
      ],
      "Resource": "arn:aws:s3:::qpress-uploads/prod/*"
    },
    {
      "Sid": "ListBucketProdPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::qpress-uploads",
      "Condition": {
        "StringLike": {"s3:prefix": ["prod/", "prod/*"]}
      }
    }
  ]
}
