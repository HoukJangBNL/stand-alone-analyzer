{
  "CORSRules": [
    {
      "ID": "qpress-uploads-browser-put",
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://127.0.0.1:5173",
        "http://127.0.0.1:5174"
      ],
      "AllowedMethods": ["PUT", "GET", "HEAD"],
      "AllowedHeaders": [
        "Authorization",
        "Content-Type",
        "x-amz-checksum-sha256",
        "x-amz-content-sha256",
        "x-amz-date",
        "x-amz-security-token"
      ],
      "ExposeHeaders": ["ETag", "x-amz-checksum-sha256"],
      "MaxAgeSeconds": 3000
    }
  ]
}
